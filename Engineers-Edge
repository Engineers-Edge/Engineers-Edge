<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Engineers Edge - Trading Journal</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    :root {
      --bg: #121212;
      --card-bg: #1E1E1E;
      --primary: #00c853;
      --danger: #ff5252;
      --text: #ffffff;
      --text-dim: #b0b0b0;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      margin: 0;
      padding: 15px;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    /* Setup/Login Overlay */
    #setup-screen {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: var(--bg);
      z-index: 1000;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 30px;
      box-sizing: border-box;
      text-align: center;
    }

    .card {
      background: var(--card-bg);
      padding: 15px;
      border-radius: 12px;
      margin-bottom: 15px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }

    .stats {
      display: flex;
      justify-content: space-between;
      gap: 10px;
    }

    .stat {
      flex: 1;
      text-align: center;
    }

    .stat div {
      font-size: 12px;
      color: var(--text-dim);
      margin-bottom: 5px;
    }

    .stat h3 {
      margin: 0;
      font-size: 16px;
    }

    input, select {
      width: 100%;
      padding: 12px;
      margin-top: 10px;
      background: #2a2a2a;
      color: white;
      border: 1px solid #333;
      border-radius: 8px;
      box-sizing: border-box;
      font-size: 16px; /* Mencegah auto-zoom di iOS */
    }

    button {
      width: 100%;
      padding: 14px;
      margin-top: 15px;
      background: var(--primary);
      border: none;
      color: white;
      font-weight: bold;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
      transition: opacity 0.2s;
    }

    button:active { opacity: 0.8; }

    .btn-reset {
      background: transparent;
      border: 1px solid #444;
      color: var(--danger);
      margin-top: 30px;
      margin-bottom: 20px;
    }

    img {
      max-width: 120px;
      height: auto;
      margin-bottom: 15px;
    }

    #history-container {
      margin-top: 10px;
    }

    .history-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      border-bottom: 1px solid #333;
    }

    .history-date { font-size: 12px; color: var(--text-dim); }
    .history-val { font-weight: bold; }

    #main-content { display: none; }
  </style>
</head>
<body>

<div id="setup-screen">
  <img src="logo.png" onerror="this.style.display='none'">
  <h2 style="margin-bottom: 5px;">Engineers Edge</h2>
  <p style="color: var(--text-dim); margin-bottom: 20px;">Trading Journal Setup</p>
  
  <input id="nicknameInput" type="text" placeholder="Masukkan Nickname Kamu">
  <select id="currencyInput">
    <option value="$">USD ($)</option>
    <option value="Rp">IDR (Rp)</option>
  </select>
  <button onclick="startApp()">MASUK DASHBOARD</button>
</div>

<div id="main-content">
  <div style="text-align:center; margin-bottom: 20px;">
    <img src="logo.png" style="max-width: 80px;" onerror="this.style.display='none'">
    <div id="display-name" style="font-weight: bold; font-size: 14px; color: var(--primary);"></div>
  </div>

  <div class="card stats">
    <div class="stat">
      <div>Profit</div>
      <h3 id="profit">0</h3>
    </div>
    <div class="stat">
      <div>Winrate</div>
      <h3 id="winrate">0%</h3>
    </div>
    <div class="stat">
      <div>Trades</div>
      <h3 id="trades">0</h3>
    </div>
  </div>

  <div class="card">
    <canvas id="chart" style="max-height: 250px;"></canvas>
  </div>

  <div class="card">
    <div style="font-size: 14px; margin-bottom: 5px;">Tambah Transaksi</div>
    <input id="profitInput" type="number" placeholder="Contoh: 100 atau -50">
    <button onclick="addTrade()">SIMPAN DATA</button>
  </div>

  <div id="history-container">
    <div style="padding-left: 5px; margin-bottom: 10px; font-size: 14px; font-weight: bold;">History</div>
    <div id="history-list" class="card" style="padding: 0;"></div>
  </div>

  <button class="btn-reset" onclick="resetData()">RESET SEMUA DATA</button>
</div>

<script>
let data = JSON.parse(localStorage.getItem("trades")) || [];
let user = JSON.parse(localStorage.getItem("user_profile")) || null;
let myChart = null;

// Jalankan saat web dibuka
window.onload = function() {
  if (user) {
    showDashboard();
  }
};

function startApp() {
  const nick = document.getElementById("nicknameInput").value.trim();
  const curr = document.getElementById("currencyInput").value;
  
  if (!nick) return alert("Nickname tidak boleh kosong!");
  
  user = { nickname: nick, currency: curr };
  localStorage.setItem("user_profile", JSON.stringify(user));
  showDashboard();
}

function showDashboard() {
  document.getElementById("setup-screen").style.display = "none";
  document.getElementById("main-content").style.display = "block";
  document.getElementById("display-name").innerText = `Trader: ${user.nickname}`;
  render();
}

function addTrade() {
  const input = document.getElementById("profitInput");
  let value = parseFloat(input.value);
  
  if (isNaN(value)) return;

  data.push({
    profit: value,
    date: new Date().toLocaleDateString('id-ID')
  });

  localStorage.setItem("trades", JSON.stringify(data));
  input.value = "";
  render();
}

function resetData() {
  if (confirm("Hapus semua data dan reset profil?")) {
    localStorage.clear();
    location.reload();
  }
}

function render() {
  let total = data.reduce((a, b) => a + b.profit, 0);
  let wins = data.filter(t => t.profit > 0).length;
  let currency = user.currency;

  // Update Stats UI
  document.getElementById("profit").innerText = `${currency}${total.toLocaleString()}`;
  document.getElementById("winrate").innerText =
    data.length ? ((wins / data.length) * 100).toFixed(0) + "%" : "0%";
  document.getElementById("trades").innerText = data.length;

  // Render Chart
  let balance = 0;
  let chartValues = data.map(t => balance += t.profit);
  let chartLabels = data.map((_, i) => i + 1);

  const ctx = document.getElementById("chart").getContext("2d");
  if (myChart) myChart.destroy();

  myChart = new Chart(ctx, {
    type: "line",
    data: {
      labels: chartLabels,
      datasets: [{
        data: chartValues,
        borderColor: "#00c853",
        backgroundColor: "rgba(0, 200, 83, 0.1)",
        fill: true,
        tension: 0.4,
        pointRadius: 4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { color: "#888" } },
        y: { grid: { color: "#333" }, ticks: { color: "#888" } }
      }
    }
  });

  // Render History
  let historyHtml = "";
  data.slice().reverse().forEach(t => {
    historyHtml += `
      <div class="history-item">
        <span class="history-date">${t.date}</span>
        <span class="history-val" style="color:${t.profit >= 0 ? 'var(--primary)' : 'var(--danger)'}">
          ${t.profit >= 0 ? '+' : ''}${t.profit}
        </span>
      </div>
    `;
  });
  document.getElementById("history-list").innerHTML = historyHtml || '<div style="padding:20px; text-align:center; color:#555;">Belum ada data</div>';
}
</script>

</body>
</html>
